{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "assignees": [
    "colby.goettel"
  ],
  "labels": [
    "renovate",
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Group sqflite family — versions must stay in sync",
      "matchPackageNames": [
        "sqflite",
        "sqflite_common_ffi",
        "sqflite_common_ffi_web"
      ],
      "groupName": "sqflite"
    },
    {
      "description": "Auto-merge patch updates when CI passes",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ]
}
